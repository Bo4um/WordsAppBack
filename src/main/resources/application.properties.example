# Copy this file to application.properties and adjust values as needed

spring.application.name=WordsApp Back
spring.profiles.active=dev

# OpenAI API Configuration
openai.api.key=YOUR_OPENAI_API_KEY
openai.api.url=https://api.openai.com/v1/responses

# Logging
logging.level.com.bo4um.wordsappback=DEBUG
logging.level.org.springframework.security=DEBUG

# H2 Database Configuration (dev only)
spring.datasource.url=jdbc:h2:file:./data/wordsapp
spring.datasource.driverClassName=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=
spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
spring.jpa.hibernate.ddl-auto=update
spring.h2.console.enabled=true
spring.h2.console.path=/h2-console

# Cache (Caffeine for dev)
spring.cache.type=caffeine
spring.cache.cache-names=wordCache
spring.cache.time-to-live=3600000

# JWT Configuration
jwt.secret=CHANGE_THIS_SECRET_KEY_FOR_PRODUCTION_MUST_BE_LONG_ENOUGH
jwt.expiration=86400000

# Stripe Configuration (for Premium subscriptions)
stripe.api.key=sk_test_YOUR_STRIPE_SECRET_KEY
stripe.webhook.secret=whsec_YOUR_WEBHOOK_SECRET
stripe.price.id.premium=price_PREMIUM_PRICE_ID
stripe.price.id.lifetime=price_LIFETIME_PRICE_ID
app.frontend.url=http://localhost:3000
